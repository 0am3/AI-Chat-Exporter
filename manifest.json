{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "version": "1.1",
  "description": "Exports chat logs from AI chatbots to Markdown.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
    "content_scripts": [
        {
        "matches": [
            "*://chatgpt.com/*", 
            "*://claude.ai/*", 
            "*://gemini.google.com/*",
            "*://chat.z.ai/*"
        ],
        "js": ["scripts/turndown.js", "scripts/content.js"]
        }
    ]
}
