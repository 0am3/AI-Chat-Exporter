{
  "manifest_version": 3,
  "name": "AI Chat Exporter",
  "version": "1.0",
  "description": "Exports chat logs from AI chatbots to Markdown.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
    "content_scripts": [
        {
        "matches": [
            "*://chatgpt.com/*", 
            "*://claude.ai/*", 
            "*://gemini.google.com/*"
        ],
        "js": ["turndown.js", "content.js"]
        }
    ]
}
